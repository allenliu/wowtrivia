          "audioUrl": "https://wow.zamimg.com/sound-ids/live/enus/248/5858808/VO_110_Stormward_Baelgrim_95_M.ogg",
          "text": "Was this an earthen once? No matter. We must destroy it!",
          "status": "pending",
          "selected": false,
          "notes": ""
        },
        {
          "soundId": 251788,
          "filename": "vo-110-stormward-baelgrim-80-m",
