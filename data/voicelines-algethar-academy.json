  "npcs": [
    {
      "id": 195587,
      "name": "Headteacher Doragosa",
      "elite": true,
      "quotes": [
        {
          "soundId": 208071,
          "filename": "vo-100-headteacher-doragosa-13-f",
          "fileDataId": 4689472,
          "audioUrl": "https://wow.zamimg.com/sound-ids/live/enus/64/4689472/VO_100_Headteacher_Doragosa_13_F.ogg",
          "text": "Oh dear. It seems that the parameters I wove into my out of office spell were a bit... extreme. Thank you for all your help in getting the school ready.",
          "status": "pending",
          "selected": false,
          "notes": ""
        },
        {
          "soundId": 208062,
          "filename": "vo-100-headteacher-doragosa-04-f",
          "fileDataId": 4689463,
          "audioUrl": "https://wow.zamimg.com/sound-ids/live/enus/55/4689463/VO_100_Headteacher_Doragosa_04_F.ogg",
          "text": "Welcome to Algeth'ar Academy! I am delighted that you received our invitation. The school is a touch behind schedule, but I have heard wondrous things about your capabilities. Perhaps you could help us?",
          "status": "pending",
          "selected": false,
          "notes": ""
        },
        {
          "soundId": 208065,
          "filename": "vo-100-headteacher-doragosa-07-f",
          "fileDataId": 4689466,
          "audioUrl": "https://wow.zamimg.com/sound-ids/live/enus/58/4689466/VO_100_Headteacher_Doragosa_07_F.ogg",
          "text": "Hmmm, we have been gone for some time. The growth here... ah! The way should be clear, please head to my office and wait. I hear new students that require my personal attention.",
          "status": "pending",
          "selected": false,
          "notes": ""
        },
        {
          "soundId": 208061,
          "filename": "vo-100-headteacher-doragosa-03-f",
          "fileDataId": 4689462,
          "audioUrl": "https://wow.zamimg.com/sound-ids/live/enus/54/4689462/VO_100_Headteacher_Doragosa_03_F.ogg",
          "text": "It appears some new students have trickled in after you. They seem interested in our sports field. Help them sort out clearing the place, it is in quite a state.",
          "status": "pending",
          "selected": false,
          "notes": ""
        },
        {
          "soundId": 208063,
          "filename": "vo-100-headteacher-doragosa-05-f",
          "fileDataId": 4689464,
          "audioUrl": "https://wow.zamimg.com/sound-ids/live/enus/56/4689464/VO_100_Headteacher_Doragosa_05_F.ogg",
          "text": "Our history professor Maxdormu is almost ready for lessons. Do see if there is anything he needs assistance with.",
          "status": "pending",
          "selected": false,
          "notes": ""
        }
      ]
    },
    {
      "id": 191933,
      "name": "Malinor",
      "elite": true,
      "quotes": [
        {
          "soundId": 209202,
          "filename": "vo-100-malinor-01-f",
          "fileDataId": 4696036,
          "audioUrl": "https://wow.zamimg.com/sound-ids/live/enus/228/4696036/VO_100_Malinor_01_F.ogg",
          "text": "All right. Now we need to clear out the big one. I will activate the goals for Lish Llrath--that is Talon Toss for you softskins. Use them to get her attention.",
          "status": "accepted",
          "selected": false,
          "notes": ""
        },
        {
          "soundId": 209203,
          "filename": "vo-100-malinor-02-f",
          "fileDataId": 4696037,
          "audioUrl": "https://wow.zamimg.com/sound-ids/live/enus/229/4696037/VO_100_Malinor_02_F.ogg",
          "text": "At least we know that works. Watch yourselves.",
          "status": "pending",
          "selected": false,
          "notes": ""
        },
        {
          "soundId": 209205,
          "filename": "vo-100-malinor-04-f",
          "fileDataId": 4696039,
          "audioUrl": "https://wow.zamimg.com/sound-ids/live/enus/231/4696039/VO_100_Malinor_04_F.ogg",
          "text": "Clear them out! They have ruined the place.",
          "status": "pending",
          "selected": false,
          "notes": ""
        },
        {
          "soundId": 209206,
          "filename": "vo-100-malinor-05-f",
          "fileDataId": 4696040,
          "audioUrl": "https://wow.zamimg.com/sound-ids/live/enus/232/4696040/VO_100_Malinor_05_F.ogg",
          "text": "Look at this Lish Llrath arena--wait, what are these birds doing here?",
          "status": "accepted",
          "selected": false,
          "notes": ""
        },
        {
          "soundId": 209204,
          "filename": "vo-100-malinor-03-f",
          "fileDataId": 4696038,
          "audioUrl": "https://wow.zamimg.com/sound-ids/live/enus/230/4696038/VO_100_Malinor_03_F.ogg",
          "text": "So many birds! Help us get rid of them!",
          "status": "pending",
          "selected": false,
          "notes": ""
        }
      ]
    },
    {
      "id": 189667,
      "name": "Professor Ichistrasz",
      "elite": true,
      "quotes": [
        {
