          "audioUrl": "https://wow.zamimg.com/sound-ids/live/enus/200/5858760/VO_110_Stormward_Baelgrim_79_M.ogg",
          "text": "This is highly irregular. Why are these stormrooks tethered here?",
          "status": "pending",
          "selected": false,
          "notes": ""
