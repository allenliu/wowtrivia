                                        "audioUrl":  "https://wow.zamimg.com/sound-ids/live/enus/64/2000448/VO_801_Brann_Bronzebeard_49_M.ogg",
                                        "text":  "Sounds like a plan. While we're at it, I'll see what other secrets the titans may have left behind.",
                                        "status":  "pending",
                                        "selected":  false,
                                        "notes":  ""
                                    },
