          "filename": "vo-100-professor-ichistrasz-03-m",
          "fileDataId": 4689570,
          "audioUrl": "https://wow.zamimg.com/sound-ids/live/enus/162/4689570/VO_100_Professor_Ichistrasz_03_M.ogg",
          "text": "Absolutely not!",
          "status": "pending",
          "selected": false,
